# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=talentflow

# ─── User Service DB ──────────────────────────────────────────
USER_DB_NAME=userdb
USER_DB_URL=postgresql://postgres:postgres123@postgres:5432/userdb

# ─── Job Service DB ───────────────────────────────────────────
JOB_DB_NAME=jobdb
JOB_DB_URL=jdbc:postgresql://postgres:5432/jobdb

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── MongoDB ──────────────────────────────────────────────────
MONGO_URI=mongodb://mongodb:27017
MONGO_DB=notifications

# ─── Kafka ────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-strong-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── SendGrid (Notification Service) ─────────────────────────
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@talentflow.com

# ─── Jaeger ───────────────────────────────────────────────────
JAEGER_AGENT_HOST=jaeger
JAEGER_AGENT_PORT=6831

# ─── Frontend ─────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080
VITE_USER_API_URL=http://localhost:8001
